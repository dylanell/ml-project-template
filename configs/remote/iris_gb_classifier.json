{
    "seed": 42,
    "data": {
        "path": "s3://data/iris/raw/iris.csv",
        "target_column": "species",
        "valid_size": 0.2
    },
    "preprocessing": {
        "scaling": "min-max",
        "output_dir": "s3://data/iris/processed"
    },
    "model": {
        "name": "gb_classifier",
        "params": {
            "n_estimators": 100,
            "max_depth": 3
        }
    },
    "training": {
        "experiment_name": "iris-gb-classifier",
        "run_name": null,
        "model_path": "s3://models/iris_gb_classifier",
        "tracking": true
    }
}